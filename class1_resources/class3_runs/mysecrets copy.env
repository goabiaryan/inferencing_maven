# API keys and secrets for Single-GPU Inference Exercise
# Copy this file to secrets.env (or .env) and fill in your values.
# NEVER commit secrets.env or .env — they are gitignored.
#
# Usage:
#   export $(grep -v '^#' secrets.env | xargs)
#   or in Python: from load_secrets import load_secrets; load_secrets()
#   or: python-dotenv: load_dotenv("secrets.env")

# --- Hugging Face (required for gated models e.g. Llama) ---
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
# Alternative env name some tools use:
# HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here

# --- Modal (optional: for running on Modal cloud) ---
# Create at https://modal.com/settings
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# --- Lambda Labs (optional: for GPU instances) ---
# Create at https://cloud.lambdalabs.com/api-keys
LAMBDA_API_KEY=your_lambda_api_key_here

# --- OpenAI (optional: only if you compare against OpenAI API) ---
# OPENAI_API_KEY=sk-...

# --- Add any other keys your class / scripts need below ---
